PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/vivid_advisory
JWT_SECRET=vivid_advisory_jwt_secret_change_in_production
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Google Drive Integration
# 1. Create a Service Account in Google Cloud Console with Drive API enabled
# 2. Download the JSON key file
# 3. Base64-encode it:  base64 -w 0 service-account.json   (Linux/Mac)
#    On Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
# 4. Paste the output below
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# Create a folder in Google Drive named "Vivid Advisory"
# Share it with the service account email (give Editor access)
# The folder ID is the string after /folders/ in the URL
GOOGLE_DRIVE_PARENT_FOLDER_ID=
